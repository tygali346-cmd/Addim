{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "volunteer", "employer", "admin"] },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "is2FAEnabled": { "type": "boolean" },
        "twoFactorPIN": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SuggestedLocation": {
      "title": "Suggested Location",
      "description": "A location suggested by a user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "addr": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "suggestedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "addr", "features", "suggestedBy", "status"]
    },
    "LocationReview": {
      "title": "Location Review",
      "description": "User reviews and star ratings for map locations",
      "type": "object",
      "properties": {
        "locationId": { "type": "integer" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["locationId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "AppFeedback": {
      "title": "App Feedback",
      "description": "Positive or negative user feedback about the ADDIM application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "type": { "type": "string", "enum": ["positive", "negative"] },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "type", "comment", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by UID"
    },
    "suggested_locations/{suggestionId}": {
      "schema": "SuggestedLocation",
      "description": "User suggested map locations pending moderation"
    },
    "location_reviews/{reviewId}": {
      "schema": "LocationReview",
      "description": "Location reviews with ratings"
    },
    "app_feedback/{feedbackId}": {
      "schema": "AppFeedback",
      "description": "User feedback submissions about the application"
    }
  }
}
