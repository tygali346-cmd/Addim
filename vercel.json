{
  "version": 2,
  "functions": {
    "api/tts.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/tts",
      "destination": "/api/tts.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!assets|favicon.ico|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
